{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Alfred Dashboard Data",
  "description": "Schema for dashboard-data.json — validated before every write to prevent corrupted pushes",
  "type": "object",
  "required": [
    "lastUpdated", "mission", "targetDate", "stats", "revenue",
    "schedule", "sprint", "tasks", "integrations", "projects",
    "agents", "liveActivity", "cronJobs", "system", "documents"
  ],
  "properties": {
    "lastUpdated": { "type": "string", "description": "ISO 8601 timestamp of last update" },
    "mission": { "type": "string", "minLength": 1 },
    "targetDate": { "type": "string" },
    "_commit_message": { "type": "string" },
    "stats": {
      "type": "object",
      "required": ["totalTasks"],
      "properties": {
        "tasksThisWeek": { "type": "integer", "minimum": 0 },
        "inProgress": { "type": "integer", "minimum": 0 },
        "totalTasks": { "type": "integer", "minimum": 0 },
        "completionPct": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "revenue": {
      "type": "object",
      "required": ["current", "target", "streams"],
      "properties": {
        "current": { "type": "number", "minimum": 0 },
        "target": { "type": "number", "minimum": 0 },
        "streams": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "current", "target", "status"],
            "properties": {
              "name": { "type": "string" },
              "current": { "type": "number" },
              "target": { "type": "number" },
              "status": { "type": "string", "enum": ["active", "planning", "notStarted", "building"] }
            }
          }
        }
      }
    },
    "schedule": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["time", "label", "description", "type"],
        "properties": {
          "time": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string", "enum": ["briefing", "strategy", "system", "content"] }
        }
      }
    },
    "sprint": {
      "type": "object",
      "required": ["currentWeek", "weeks"],
      "properties": {
        "currentWeek": { "type": "integer", "minimum": 1 },
        "weeks": { "type": "array" }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "priority", "project", "assignee"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["backlog", "in-progress", "review", "done"] },
          "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "project": { "type": "string" },
          "assignee": { "type": "string" },
          "delegatedTo": { "type": "string" },
          "createdAt": { "type": "string" },
          "completedAt": { "type": ["string", "null"] },
          "projectColor": { "type": "string" }
        }
      }
    },
    "integrations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "configured", "planned", "error"] },
          "icon": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "description", "phase", "color", "icon"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "planning", "notStarted", "building"] },
          "description": { "type": "string" },
          "phase": { "type": "string" },
          "progress": { "type": "integer", "minimum": 0, "maximum": 100 },
          "color": { "type": "string" },
          "icon": { "type": "string" }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "role", "status", "color", "icon", "skills"],
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "idle", "inactive"] },
          "description": { "type": "string" },
          "model": { "type": "string" },
          "color": { "type": "string" },
          "icon": { "type": "string" },
          "skills": { "type": "array", "items": { "type": "string" } },
          "currentTask": { "type": ["string", "null"] }
        }
      }
    },
    "liveActivity": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent", "action", "timestamp"],
        "properties": {
          "agent": { "type": "string" },
          "action": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    },
    "cronJobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "schedule", "status"],
        "properties": {
          "name": { "type": "string" },
          "schedule": { "type": "string" },
          "lastRun": { "type": ["string", "null"] },
          "nextRun": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["active", "paused", "error"] }
        }
      }
    },
    "system": {
      "type": "object",
      "required": ["model", "container", "os", "node"],
      "properties": {
        "model": { "type": "string" },
        "container": { "type": "string" },
        "os": { "type": "string" },
        "node": { "type": "string" },
        "openclawVersion": { "type": "string" },
        "hostname": { "type": "string" }
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "category": { "type": "string" },
          "type": { "type": "string" },
          "size": { "type": "integer" },
          "content": { "type": "string" },
          "createdAt": { "type": "string" }
        }
      }
    },
    "personal": {
      "type": "object",
      "properties": {
        "calendar": { "type": "array" },
        "people": { "type": "array" },
        "mind": { "type": "object" },
        "body": { "type": "object" },
        "spirit": { "type": "object" },
        "profile": { "type": "object" }
      }
    }
  },
  "additionalProperties": true
}
